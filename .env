# ─────────────────────────────────────────
#  EarthWatch India — API Keys
#  Fill these in. All are FREE.
# ─────────────────────────────────────────

# NASA FIRMS — fire detection (free, instant)
# Get at: firms.modaps.eosdis.nasa.gov/api/
NASA_FIRMS_KEY=your_firms_key_here

# OpenWeatherMap — rain/flood data (free, instant)
# Get at: openweathermap.org/api
OPENWEATHER_KEY=your_openweather_key_here

# OpenAQ — air quality (free, instant)
# Get at: explore.openaq.org
OPENAQ_KEY=your_openaq_key_here

# Mapbox — map display (free, instant)
# Get at: mapbox.com
MAPBOX_TOKEN=your_mapbox_token_here

# App settings
PORT=8000
APP_NAME=EarthWatch India
